# Provider binary
terraform-provider-asgardeo
terraform-provider-asgardeo_*

# Terraform working files
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan

# Go build artefacts
*.exe
*.test
*.out
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Terraform variable files — may contain credentials, never commit
*.tfvars
*.tfvars.json
# Exception: example tfvars that contain only placeholder values are allowed
!examples/**/*.tfvars.example

# Environment / secrets — never commit these
.env
*.env
